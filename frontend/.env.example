# SkillFi Frontend — copy to .env and fill in real values

# Backend API base URL (deployed or localhost)
VITE_API_URL=http://localhost:5000

# Stellar Soroban RPC
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Deployed Soroban contract addresses (fill after deploying)
VITE_REGISTRY_CONTRACT_ID=
VITE_POOL_CONTRACT_ID=
VITE_DISTRIBUTOR_CONTRACT_ID=

# PostHog analytics (optional — leave blank to disable, get key at posthog.com)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# Sentry error monitoring (optional — get DSN at sentry.io, free tier)
VITE_SENTRY_DSN=
