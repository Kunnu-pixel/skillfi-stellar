# SkillFi Backend — copy to .env and fill in real values

PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Stellar Soroban RPC
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Deployed Soroban contract addresses (fill after deploying)
REGISTRY_CONTRACT_ID=
POOL_CONTRACT_ID=
DISTRIBUTOR_CONTRACT_ID=

# SQLite DB path (defaults to ./skillfi.db)
DB_PATH=./skillfi.db

# File uploads directory (defaults to ./uploads)
UPLOADS_DIR=./uploads

# Sentry error monitoring DSN (optional — get from sentry.io free tier)
SENTRY_DSN=
